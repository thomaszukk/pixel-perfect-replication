# =============================================================================
# Security Headers -- zukk.com.br
# =============================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # SPA routing -- redireciona tudo para index.html
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # HSTS -- force HTTPS por 1 ano (browsers vao cachear)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Impede MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Impede clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Referrer controlado
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restringe acesso a APIs sensíveis do browser
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"

  # Content Security Policy
  # 'unsafe-inline' necessario para Vite build com inline styles do Tailwind/Radix
  # Apertar apos validar que nao quebra nada em prod
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https:; media-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
</IfModule>
